{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2023",
    "types": ["node"],
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "moduleDetection": "force",
    "resolvePackageJsonImports": true,
    "resolveJsonModule": true,
    "preserveConstEnums": true,
    "useDefineForClassFields": true,
    "noImplicitThis": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "strictBuiltinIteratorReturn": true,
    "alwaysStrict": true,
    "useUnknownInCatchVariables": true
  },
  "files": [
    "./src/app.controller.ts",
    "./src/app.module.ts",
    "./src/app.service.ts",
    "./src/main.ts",
    "./src/auth/auth.controller.ts",
    "./src/auth/auth.module.ts",
    "./src/auth/auth.service.ts",
    "./src/auth/decorators/Authorization.decorator.ts",
    "./src/auth/decorators/authorized.decorator.ts",
    "./src/auth/dto/auth.dto.ts",
    "./src/auth/dto/forgot-password.dto.ts",
    "./src/auth/dto/login.dto.ts",
    "./src/auth/dto/register.dto.ts",
    "./src/auth/dto/reset-password.dto.ts",
    "./src/auth/guards/auth.guard.ts",
    "./src/auth/interfaces/auth.interfaces.ts",
    "./src/auth/interfaces/jwt.interfaces.ts",
    "./src/auth/services/password.service.ts",
    "./src/auth/services/session.service.ts",
    "./src/auth/services/token.service.ts",
    "./src/auth/strategies/jwt.strategies.ts",
    "./src/email/email.module.ts",
    "./src/email/email.service.ts",
    "./src/generated/prisma/client.d.ts",
    "./src/generated/prisma/default.d.ts",
    "./src/generated/prisma/edge.d.ts",
    "./src/generated/prisma/index.d.ts",
    "./src/generated/prisma/runtime/client.d.ts",
    "./src/generated/prisma/runtime/index-browser.d.ts",
    "./src/prismas/prisma.module.ts",
    "./src/prismas/prisma.service.ts"
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma", "prisma.config.ts"]
}
